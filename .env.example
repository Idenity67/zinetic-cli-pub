# Zinetic CLI public installer — no application runtime env.
# These affect install.sh only (binary downloads from GitHub Releases).

# ZIN_VERSION=latest
# ZIN_INSTALL_DIR=$HOME/.local/bin
# ZIN_REQUIRE_SIGSTORE=true
# ZIN_SKIP_SIGSTORE=false
# ZIN_GITHUB_TOKEN=
# ZIN_PUB_REPO=Idenity67/zinetic-cli-pub
# ZIN_RELEASE_BASE_URL=

# After install, configure the CLI via ~/.zin/config.yaml or:
#   export ZIN_API_URL=https://api.zinetic.net/api/v1
#   export ZIN_IDP_URL=https://auth.zinetic.net/realms/zinetic
#   export ZIN_CLIENT_ID=zin-cli
